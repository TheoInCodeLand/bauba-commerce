<%- include('../../partials/header') %>
<h1><%= brand ? 'Edit Brand' : 'Add Brand' %></h1>

<% if (errors && errors.length > 0) { %>
<div class="alert alert-error">
  <ul>
    <% errors.forEach(err => { %>
    <li><%= err.msg %></li>
    <% }) %>
  </ul>
</div>
<% } %>

<form action="<%= brand ? '/admin/brands/' + brand.id : '/admin/brands' %>" method="POST" class="admin-form">
  <div class="form-grid">
    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= brand ? brand.name : '' %>" required>
    </div>

    <div class="form-group">
      <label for="logoUrl">Logo URL</label>
      <input type="url" id="logoUrl" name="logoUrl" value="<%= brand ? brand.logo_url : '' %>" placeholder="https://...">
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="3"><%= brand ? brand.description : '' %></textarea>
    </div>

    <div class="form-checkbox">
      <label>
        <input type="checkbox" name="isActive" <%= brand && brand.is_active ? 'checked' : '' %>> Active
      </label>
    </div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= brand ? 'Update Brand' : 'Create Brand' %></button>
    <a href="/admin/brands" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<%- include('../../partials/footer') %>
