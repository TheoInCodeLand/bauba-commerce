<%- include('../../partials/header') %>
<h1><%= tag ? 'Edit Tag' : 'Add Tag' %></h1>

<% if (errors && errors.length > 0) { %>
<div class="alert alert-error">
  <ul>
    <% errors.forEach(err => { %>
    <li><%= err.msg %></li>
    <% }) %>
  </ul>
</div>
<% } %>

<form action="<%= tag ? '/admin/tags/' + tag.id : '/admin/tags' %>" method="POST" class="admin-form">
  <div class="form-grid">
    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= tag ? tag.name : '' %>" required>
    </div>

    <div class="form-group">
      <label for="type">Type</label>
      <select id="type" name="type">
        <option value="general" <%= tag && tag.type === 'general' ? 'selected' : '' %>>General</option>
        <option value="color" <%= tag && tag.type === 'color' ? 'selected' : '' %>>Color</option>
        <option value="size" <%= tag && tag.type === 'size' ? 'selected' : '' %>>Size</option>
        <option value="material" <%= tag && tag.type === 'material' ? 'selected' : '' %>>Material</option>
      </select>
    </div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= tag ? 'Update Tag' : 'Create Tag' %></button>
    <a href="/admin/tags" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<%- include('../../partials/footer') %>
