<%- include('../../partials/header') %>
<h1><%= department ? 'Edit Department' : 'Add Department' %></h1>

<% if (errors && errors.length > 0) { %>
<div class="alert alert-error">
  <ul>
    <% errors.forEach(err => { %>
    <li><%= err.msg %></li>
    <% }) %>
  </ul>
</div>
<% } %>

<form action="<%= department ? '/admin/departments/' + department.id : '/admin/departments' %>" method="POST" class="admin-form">
  <div class="form-grid">
    <div class="form-group">
      <label for="name">Name</label>
      <input type="text" id="name" name="name" value="<%= department ? department.name : '' %>" required>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="3"><%= department ? department.description : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="imageUrl">Image URL</label>
      <input type="url" id="imageUrl" name="imageUrl" value="<%= department ? department.image_url : '' %>" placeholder="https://...">
    </div>

    <div class="form-group">
      <label for="sortOrder">Sort Order</label>
      <input type="number" id="sortOrder" name="sortOrder" min="0" value="<%= department ? department.sort_order : '0' %>">
    </div>

    <div class="form-checkbox">
      <label>
        <input type="checkbox" name="isActive" <%= department && department.is_active ? 'checked' : '' %>> Active
      </label>
    </div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= department ? 'Update Department' : 'Create Department' %></button>
    <a href="/admin/departments" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<%- include('../../partials/footer') %>
