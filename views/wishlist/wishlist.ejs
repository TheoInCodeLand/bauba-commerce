<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= title %></h1>
  <p class="text-muted"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %> saved</p>
</div>

<% if (!items || items.length === 0) { %>
<div class="empty-state">
  <div class="empty-icon">♡</div>
  <p>Your wishlist is empty.</p>
  <p class="text-muted">Browse products and tap the heart to save items you love.</p>
  <a href="/products" class="btn btn-primary">Browse Products</a>
</div>
<% } else { %>
<div class="product-grid">
  <% items.forEach(item => { %>
  <article class="product-card wishlist-card">
    <a href="/products/<%= item.slug || item.id %>" class="product-link">
      <div class="product-image">
        <img src="<%= item.image_url || '/images/placeholder.jpg' %>" alt="<%= item.name %>" loading="lazy">
      </div>
      <div class="product-info">
        <h3><%= item.name %></h3>
        <p class="product-category"><%= item.category_name || 'Uncategorized' %></p>
        <% if (item.average_rating > 0) { %>
        <div class="product-meta-inline">
          <span class="rating-stars-small">
            <% for (let i = 1; i <= 5; i++) { %>
              <span class="star <%= i <= Math.round(Number(item.average_rating)) ? 'filled' : '' %>">★</span>
            <% } %>
          </span>
          <span class="rating-count">(<%= item.review_count || 0 %>)</span>
        </div>
        <% } %>
        <% if (item.discount_price) { %>
        <p class="product-price">
          <span class="price-old">ZAR <%= item.price %></span>
          <strong>ZAR <%= item.discount_price %></strong>
        </p>
        <% } else { %>
        <p class="product-price">ZAR <%= item.price %></p>
        <% } %>
      </div>
    </a>

    <div class="wishlist-card-actions">
      <form action="/cart/add" method="POST" class="add-to-cart-form">
        <input type="hidden" name="productId" value="<%= item.id %>">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="btn btn-primary btn-small" <%= item.stock_quantity <= 0 ? 'disabled' : '' %>>
          <%= item.stock_quantity <= 0 ? 'Out of Stock' : 'Add to Cart' %>
        </button>
      </form>
      <form action="/wishlist/toggle" method="POST" class="wishlist-toggle-form">
        <input type="hidden" name="productId" value="<%= item.id %>">
        <button type="submit" class="btn-wishlist-remove" title="Remove from wishlist">
          <span class="heart-icon">♥</span> Remove
        </button>
      </form>
    </div>
  </article>
  <% }) %>
</div>
<% } %>

<%- include('../partials/footer') %>
