<%- include('partials/bauba-header', { title: title, bodyClass: 'home-page' }) %>

<!-- ─── HERO BANNER ─── -->
<div class="hero" id="hero">
  <div class="hero-slide">
    <div class="hero-left">
      <div class="hero-sale-row">
        <span class="hero-tks">bauba</span>
        <span class="hero-sale-pill">sale</span>
      </div>
      <div class="hero-tagline">Shop smarter, live better.</div>
      <div class="hero-savebox">
        <div class="lbl">save up to</div>
        <div class="pct">60%</div>
      </div>
      <div class="hero-date">Daily deals on electronics, home &amp; more</div>
    </div>

    <div class="hero-prods">
      <div class="h-prod" style="width:65px;height:85px;font-size:30px">🔧</div>
      <div class="h-prod" style="width:80px;height:100px;font-size:38px">🧹</div>
      <div class="h-prod" style="width:65px;height:75px;font-size:28px">🫧</div>
    </div>

    <div class="hero-right">
      <% if (discounted && discounted.length > 0) { %>
      <% const heroProd = discounted[0]; %>
      <div class="tv-screen">
        <% if (heroProd.image_url) { %>
        <img src="<%= heroProd.image_url %>" alt="<%= heroProd.name %>" style="width:100%;height:100%;object-fit:cover;border-radius:4px;">
        <% } else { %>
        <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:40px">🏷️</div>
        <% } %>
      </div>
      <div class="sky-info">
        <div class="sky-brand" style="font-size:13px;max-width:170px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= heroProd.brand_name || 'Featured Deal' %></div>
        <div class="sky-sub" style="font-size:15px;max-width:170px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= heroProd.name %></div>
        <div class="tv-specs">
          <span style="color:#fff;font-weight:700">R<%= Number(heroProd.discount_price || heroProd.price).toLocaleString() %></span>
          <% if (heroProd.discount_price && heroProd.price > heroProd.discount_price) { %>
          <span style="color:rgba(255,255,255,.35)">·</span>
          <span style="text-decoration:line-through;opacity:.7">R<%= Number(heroProd.price).toLocaleString() %></span>
          <% } %>
        </div>
      </div>
      <% } else { %>
      <div class="tv-screen">
        <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:40px">📦</div>
      </div>
      <div class="sky-info">
        <div class="sky-brand">BAUBA</div>
        <div class="sky-sub">Deals<sup>+</sup></div>
        <div class="tv-specs"><span>Fast</span><span style="color:rgba(255,255,255,.35)">·</span><span>Safe</span><span style="color:rgba(255,255,255,.35)">·</span><span>Easy</span></div>
      </div>
      <% } %>
    </div>
  </div>
  <div class="hero-dots">
    <div class="hero-dot on"></div>
    <div class="hero-dot"></div>
    <div class="hero-dot"></div>
    <div class="hero-dot"></div>
  </div>
</div>

<!-- ─── FEATURED BRANDS ─── -->
<% if (brands && brands.length > 0) { %>
<div class="sec-head"><span class="sec-title" style="font-size:17px">Featured Brands</span></div>
<div class="brands-row">
  <button class="brand-arr" id="brandArrL" aria-label="Previous brands"><i class="fas fa-chevron-left"></i></button>
  <div class="brands-list" id="brandsList">
    <% brands.forEach(brand => { %>
    <a href="/products?brand=<%= brand.id %>" class="brand-cell" aria-label="Browse <%= brand.name %>">
      <% if (brand.logo_url) { %>
      <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="brand-logo-img" loading="lazy">
      <% } else { %>
      <span class="brand-logo"><%= brand.name %></span>
      <% } %>
    </a>
    <% }) %>
  </div>
  <button class="brand-arr" id="brandArrR" aria-label="Next brands"><i class="fas fa-chevron-right"></i></button>
</div>
<% } %>

<!-- ─── CONTINUE BROWSING (client hydrated) ─── -->
<section class="home-section fade-up" id="recent-category-section" aria-label="Continue Browsing" style="display:none;">
  <div class="sec-head">
    <span class="sec-title">Continue Browsing</span>
  </div>
  <div id="recent-category-container"></div>
</section>

<!-- ─── RECENTLY VIEWED (client hydrated) ─── -->
<section class="home-section fade-up" id="recently-viewed-section" aria-label="Recently Viewed" style="display:none;">
  <div class="sec-head">
    <span class="sec-title">Pick Up Where You Left Off</span>
    <div class="sec-actions">
      <button class="ghost-btn" onclick="window.location.href='/products'">View More</button>
      <button class="ghost-btn" id="clearRecentBtn">Clear All</button>
    </div>
  </div>
  <div class="pcarousel-wrap">
    <button class="cnav lft" aria-label="Previous"><i class="fas fa-chevron-left"></i></button>
    <div class="pcarousel" id="recently-viewed-grid"></div>
    <button class="cnav rgt" aria-label="Next"><i class="fas fa-chevron-right"></i></button>
  </div>
</section>

<!-- ─── SHOP DISCOUNTED ─── -->
<% if (discounted && discounted.length > 0) { %>
<section class="home-section fade-up" id="deals" aria-label="Shop Discounts">
  <div class="sec-head">
    <span class="sec-title">Shop Discounted</span>
    <a href="/products?isDiscounted=true&" class="ghost-btn">See all deals →</a>
  </div>
  <div class="pcarousel-wrap">
    <button class="cnav lft" aria-label="Previous"><i class="fas fa-chevron-left"></i></button>
    <div class="pcarousel" role="list">
      <% discounted.forEach((product, i) => { %>
      <a href="/products/<%= product.slug || product.id %>" class="pcard fade-up" role="listitem" id="deal-product-<%= product.id %>" aria-label="<%= product.name %> — <%= product.discount_pct || 0 %>% off" style="transition-delay: <%= i * 60 %>ms">
        <div class="pcard-img-wrap">
          <% if (product.discount_pct) { %>
          <div class="sbadge">
            <div class="b-pct"><%= product.discount_pct %>%<small>OFF</small></div>
          </div>
          <% } %>
          <% if (product.image_url) { %>
          <img src="<%= product.image_url %>" alt="<%= product.name %>" class="pcard-img" loading="lazy">
          <% } else { %>
          <div class="pcard-img-placeholder" aria-hidden="true">🏷️</div>
          <% } %>
        </div>
        <div class="pcard-body">
          <% if (product.brand_name) { %><div class="pcard-brand"><%= product.brand_name %></div><% } %>
          <div class="pcard-name"><%= product.name %></div>
          <div class="price-row">
            <span class="p-main">R<%= Number(product.discount_price || product.price).toLocaleString() %></span>
            <% if (product.discount_price && product.price > product.discount_price) { %>
            <span class="p-was">R<%= Number(product.price).toLocaleString() %></span>
            <% } %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <button class="cnav rgt" aria-label="Next"><i class="fas fa-chevron-right"></i></button>
  </div>
</section>
<% } %>

<!-- ─── PROMO BANNER ─── -->
<div class="absa-banner fade-up">
  <div class="absa-left">
    <div class="absa-title1">bauba <span class="absa-sale-pill">rewards</span></div>
    <div class="absa-title2">(<span class="absa-red">members</span>)</div>
    <div class="absa-body">Shop daily deals and</div>
    <div class="absa-pct-box">
      <div class="absa-pct">get up to 30%</div>
      <div class="absa-small">*Real cash back on selected items</div>
      <div class="absa-small">New deals every week</div>
      <div class="absa-tcs">*Depending on promotions. T&amp;Cs apply.</div>
    </div>
  </div>
  <div class="absa-circle">(bauba)</div>
</div>

<!-- ─── NEW ARRIVALS ─── -->
<% if (newArrivals && newArrivals.length > 0) { %>
<section class="home-section fade-up" id="new-arrivals" aria-label="New Arrivals">
  <div class="sec-head">
    <span class="sec-title">New Arrivals</span>
    <a href="/products?sort=newest" class="ghost-btn">See all →</a>
  </div>
  <div class="pcarousel-wrap">
    <button class="cnav lft" aria-label="Previous"><i class="fas fa-chevron-left"></i></button>
    <div class="pcarousel" role="list">
      <% newArrivals.forEach((product, i) => { %>
      <a href="/products/<%= product.slug || product.id %>" class="pcard fade-up" role="listitem" id="new-product-<%= product.id %>" aria-label="<%= product.name %>" style="transition-delay: <%= i * 50 %>ms">
        <div class="pcard-img-wrap">
          <span class="pcard__badge pcard__badge--new">New</span>
          <% if (product.image_url) { %>
          <img src="<%= product.image_url %>" alt="<%= product.name %>" class="pcard-img" loading="lazy">
          <% } else { %>
          <div class="pcard-img-placeholder" aria-hidden="true">📦</div>
          <% } %>
        </div>
        <div class="pcard-body">
          <% if (product.brand_name) { %><div class="pcard-brand"><%= product.brand_name %></div><% } %>
          <div class="pcard-name"><%= product.name %></div>
          <div class="price-row">
            <% if (product.discount_price) { %>
            <span class="p-main">R<%= Number(product.discount_price).toLocaleString() %></span>
            <span class="p-was">R<%= Number(product.price).toLocaleString() %></span>
            <% } else { %>
            <span class="p-main">R<%= Number(product.price).toLocaleString() %></span>
            <% } %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <button class="cnav rgt" aria-label="Next"><i class="fas fa-chevron-right"></i></button>
  </div>
</section>
<% } %>

<!-- ─── CATEGORY SALE BANNERS (Departments) ─── -->
<% if (departments && departments.length > 0) { %>
<section class="home-section fade-up" id="departments" aria-label="Shop by Department">
  <div class="catgrid" role="list">
    <% const catColors = ['#7b1fa2','#2e7d32','#6d4c1e','#c2185b','#1565c0','#e64a19','#5e35b1','#00838f']; %>
    <% const catEmojis = ['🍾','🏡','🛍️','👠','📱','🏠','💄','⚽']; %>
    <% departments.slice(0, 4).forEach((dept, i) => { %>
    <a href="/products?department=<%= dept.id %>" class="catbanner fade-up" role="listitem" id="dept-card-<%= dept.id %>" aria-label="Browse <%= dept.name %>" style="transition-delay: <%= i * 50 %>ms">
      <div class="cat-inner">
        <div class="cat-tag-row"><span class="cat-tks">bauba</span><span class="cat-sale-pill">sale</span><span class="cat-save-txt">save up to</span></div>
        <div class="cat-pct"><%= [55,50,40,50][i] || 40 %>%</div>
        <div class="cat-name-pill" style="background:<%= catColors[i % catColors.length] %>"><%= dept.name %></div>
        <div class="cat-ghost"><%= catEmojis[i % catEmojis.length] %></div>
      </div>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- ─── TRENDING DEALS ─── -->
<% if (trending && trending.length > 0) { %>
<section class="home-section fade-up" id="trending" aria-label="Trending Deals">
  <div class="sec-head">
    <span class="sec-title">Trending Deals</span>
    <a href="/products?sort=newest" class="ghost-btn">See all →</a>
  </div>
  <div class="pcarousel-wrap">
    <button class="cnav lft" aria-label="Previous"><i class="fas fa-chevron-left"></i></button>
    <div class="pcarousel" role="list">
      <% trending.forEach((product, i) => { %>
      <a href="/products/<%= product.slug || product.id %>" class="pcard fade-up" role="listitem" id="trending-product-<%= product.id %>" aria-label="<%= product.name %>" style="transition-delay: <%= i * 50 %>ms">
        <div class="pcard-img-wrap">
          <span class="pcard__badge pcard__badge--trending">Trending</span>
          <% if (product.image_url) { %>
          <img src="<%= product.image_url %>" alt="<%= product.name %>" class="pcard-img" loading="lazy">
          <% } else { %>
          <div class="pcard-img-placeholder" aria-hidden="true">⚡</div>
          <% } %>
        </div>
        <div class="pcard-body">
          <% if (product.brand_name) { %><div class="pcard-brand"><%= product.brand_name %></div><% } %>
          <div class="pcard-name"><%= product.name %></div>
          <div class="price-row">
            <% if (product.discount_price) { %>
            <span class="p-main">R<%= Number(product.discount_price).toLocaleString() %></span>
            <span class="p-was">R<%= Number(product.price).toLocaleString() %></span>
            <% } else { %>
            <span class="p-main">R<%= Number(product.price).toLocaleString() %></span>
            <% } %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <button class="cnav rgt" aria-label="Next"><i class="fas fa-chevron-right"></i></button>
  </div>
</section>
<% } %>

</main>
<%- include('partials/bauba-footer') %>