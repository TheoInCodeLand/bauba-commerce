<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bauba — Shop Smarter, Live Better</title>
  <meta name="description" content="Discover thousands of products across electronics, fashion, home & more. Shop discounts, trending deals, and new arrivals every day at Bauba.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/home.css">
</head>
<body class="home-page">

<%- include('partials/navbar') %>

<!-- ══════════════════════════════════════════════
     HERO BANNER
══════════════════════════════════════════════ -->
<section class="hero" id="hero">
  <div class="hero__bg"></div>
  <div class="hero__grid"></div>
  <div class="hero__inner">
    <div class="hero__content fade-up">
      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        New arrivals dropping weekly
      </div>
      <h1 class="hero__heading">
        Shop Smarter,<br>
        <span>Live Better.</span>
      </h1>
      <p class="hero__sub">
        Thousands of products across fashion, electronics, home &amp; more —
        at prices that make sense. Deals updated daily.
      </p>
      <div class="hero__actions">
        <a href="/products" class="btn-hero-primary" id="hero-shop-now">
          Shop Now
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#departments" class="btn-hero-secondary" id="hero-browse-dept">
          Browse Departments
        </a>
      </div>
      <div class="hero__stats">
        <div>
          <span class="hero__stat-value"><%= brands.length %>+</span>
          <span class="hero__stat-label">Brands</span>
        </div>
        <div>
          <span class="hero__stat-value"><%= departments.length %>+</span>
          <span class="hero__stat-label">Departments</span>
        </div>
        <div>
          <span class="hero__stat-value"><%= discounted.length %>+</span>
          <span class="hero__stat-label">Live Deals</span>
        </div>
      </div>
    </div>

    <!-- Floating product snippets (visual only) -->
    <div class="hero__visual" aria-hidden="true">
      <div class="hero__card-float hero__card-float--a">
        <div class="hero__card-icon icon-bg-purple">🔥</div>
        <div class="hero__card-info">
          <strong>Hot Deals</strong>
          <span>Up to 70% off</span>
        </div>
      </div>
      <div class="hero__card-float hero__card-float--b">
        <div class="hero__card-icon icon-bg-teal">✨</div>
        <div class="hero__card-info">
          <strong>New Arrivals</strong>
          <span>Fresh every week</span>
        </div>
      </div>
      <div class="hero__card-float hero__card-float--c">
        <div class="hero__card-icon icon-bg-red">⚡</div>
        <div class="hero__card-info">
          <strong>Flash Sales</strong>
          <span>Limited time only</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     FEATURED BRANDS (auto-scroll marquee)
══════════════════════════════════════════════ -->
<% if (brands && brands.length > 0) { %>
<section class="brands-section" id="brands" aria-label="Featured Brands">
  <div class="home-section__header home-wrap">
    <h2 class="home-section__title">Featured Brands</h2>
    <a href="/products" class="home-section__link">View all →</a>
  </div>
  <div class="brands-track-outer">
    <%
      /* Duplicate the list so the marquee loops seamlessly */
      const doubledBrands = [...brands, ...brands];
    %>
    <div class="brands-track" id="brands-track" role="list">
      <% doubledBrands.forEach((brand, i) => { %>
      <a href="/products?brand=<%= brand.id %>"
         class="brand-pill"
         role="listitem"
         id="brand-pill-<%= i %>"
         aria-label="Browse <%= brand.name %> products">
        <% if (brand.logo_url) { %>
          <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="brand-pill__logo" loading="lazy">
        <% } else { %>
          <span class="brand-pill__initial" aria-hidden="true"><%= brand.name.charAt(0).toUpperCase() %></span>
        <% } %>
        <span class="brand-pill__name"><%= brand.name %></span>
      </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<div class="home-wrap">

  <!-- ══════════════════════════════════════════════
       RECENTLY VIEWED CATEGORY
  ══════════════════════════════════════════════ -->
  <% if (recentCategory) { %>
  <section class="home-section fade-up" aria-label="Continue Browsing">
    <div class="home-section__header">
      <h2 class="home-section__title">Continue Browsing</h2>
    </div>
    <a href="/products?category=<%= recentCategory.id %>"
       class="recent-cat-banner"
       id="recent-category-banner">
      <div class="recent-cat-banner__icon" aria-hidden="true">🗂️</div>
      <div>
        <div class="recent-cat-banner__label">Where you left off</div>
        <div class="recent-cat-banner__name"><%= recentCategory.name %></div>
      </div>
      <div class="recent-cat-banner__cta">Browse Category →</div>
    </a>
  </section>
  <% } %>

  <!-- ══════════════════════════════════════════════
       RECENTLY VIEWED ITEMS
  ══════════════════════════════════════════════ -->
  <% if (recentlyViewed && recentlyViewed.length > 0) { %>
  <section class="home-section fade-up" id="recently-viewed" aria-label="Recently Viewed">
    <div class="home-section__header">
      <h2 class="home-section__title">Recently Viewed</h2>
      <a href="/products" class="home-section__link">Browse all →</a>
    </div>
    <div class="product-scroll" role="list">
      <% recentlyViewed.forEach((product, i) => { %>
      <a href="/products/<%= product.slug || product.id %>"
         class="pcard"
         role="listitem"
         id="rv-product-<%= product.id %>"
         aria-label="<%= product.name %>">
        <div class="pcard__img-wrap">
          <% if (product.image_url) { %>
            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="pcard__img" loading="lazy">
          <% } else { %>
            <div class="pcard__img-placeholder" aria-hidden="true">🛍️</div>
          <% } %>
        </div>
        <div class="pcard__body">
          <% if (product.brand_name) { %><span class="pcard__brand"><%= product.brand_name %></span><% } %>
          <div class="pcard__name"><%= product.name %></div>
          <div class="pcard__pricing">
            <% if (product.discount_price) { %>
              <span class="pcard__price pcard__price--sale">R<%= Number(product.discount_price).toFixed(2) %></span>
              <span class="pcard__price-original">R<%= Number(product.price).toFixed(2) %></span>
            <% } else { %>
              <span class="pcard__price">R<%= Number(product.price).toFixed(2) %></span>
            <% } %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- ══════════════════════════════════════════════
       SHOP DISCOUNTED
  ══════════════════════════════════════════════ -->
  <section class="home-section fade-up" id="deals" aria-label="Shop Discounts">
    <div class="home-section__header">
      <h2 class="home-section__title">🔥 Shop Discounted</h2>
      <a href="/products" class="home-section__link">See all deals →</a>
    </div>
    <% if (discounted && discounted.length > 0) { %>
    <div class="product-grid-4" role="list">
      <% discounted.slice(0, 8).forEach((product, i) => { %>
      <a href="/products/<%= product.slug || product.id %>"
         class="pcard fade-up"
         role="listitem"
         id="deal-product-<%= product.id %>"
         aria-label="<%= product.name %> — <%= product.discount_pct %>% off"
         style="transition-delay: <%= i * 60 %>ms">
        <div class="pcard__img-wrap">
          <% if (product.image_url) { %>
            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="pcard__img" loading="lazy">
          <% } else { %>
            <div class="pcard__img-placeholder" aria-hidden="true">🏷️</div>
          <% } %>
          <span class="pcard__badge pcard__badge--sale">Sale</span>
          <% if (product.discount_pct) { %>
          <span class="pcard__discount-pct">-<%= product.discount_pct %>%</span>
          <% } %>
        </div>
        <div class="pcard__body">
          <% if (product.brand_name) { %><span class="pcard__brand"><%= product.brand_name %></span><% } %>
          <div class="pcard__name"><%= product.name %></div>
          <div class="pcard__pricing">
            <span class="pcard__price pcard__price--sale">R<%= Number(product.discount_price).toFixed(2) %></span>
            <span class="pcard__price-original">R<%= Number(product.price).toFixed(2) %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="home-empty">
      <div class="home-empty__icon">🏷️</div>
      <div class="home-empty__text">No discounted products right now. Check back soon!</div>
    </div>
    <% } %>
  </section>

  <!-- ══════════════════════════════════════════════
       SHOP BY DEPARTMENT
  ══════════════════════════════════════════════ -->
  <section class="home-section fade-up" id="departments" aria-label="Shop by Department">
    <div class="home-section__header">
      <h2 class="home-section__title">Shop by Department</h2>
    </div>
    <% if (departments && departments.length > 0) { %>
    <div class="dept-grid" role="list">
      <%
        const deptIcons = ['🛍️','📱','👗','🏠','💄','🎮','🍳','📚','⚽','🚗','🌿','🎨'];
      %>
      <% departments.forEach((dept, i) => { %>
      <a href="/products?department=<%= dept.id %>"
         class="dept-card fade-up"
         role="listitem"
         id="dept-card-<%= dept.id %>"
         aria-label="Browse <%= dept.name %>"
         style="transition-delay: <%= i * 50 %>ms">
        <% if (dept.image_url) { %>
          <img src="<%= dept.image_url %>" alt="" class="dept-card__img" loading="lazy">
        <% } else { %>
          <div class="dept-card__icon" aria-hidden="true"><%= deptIcons[i % deptIcons.length] %></div>
        <% } %>
        <span class="dept-card__name"><%= dept.name %></span>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="home-empty">
      <div class="home-empty__icon">🗂️</div>
      <div class="home-empty__text">Departments coming soon.</div>
    </div>
    <% } %>
  </section>

  <!-- ══════════════════════════════════════════════
       NEW ARRIVALS
  ══════════════════════════════════════════════ -->
  <% if (newArrivals && newArrivals.length > 0) { %>
  <section class="home-section fade-up" id="new-arrivals" aria-label="New Arrivals">
    <div class="home-section__header">
      <h2 class="home-section__title">✨ New Arrivals</h2>
      <a href="/products?sort=newest" class="home-section__link">See all →</a>
    </div>
    <div class="product-scroll" role="list">
      <% newArrivals.forEach((product, i) => { %>
      <a href="/products/<%= product.slug || product.id %>"
         class="pcard"
         role="listitem"
         id="new-product-<%= product.id %>"
         aria-label="<%= product.name %>">
        <div class="pcard__img-wrap">
          <% if (product.image_url) { %>
            <img src="<%= product.image_url %>" alt="<%= product.name %>" class="pcard__img" loading="lazy">
          <% } else { %>
            <div class="pcard__img-placeholder" aria-hidden="true">📦</div>
          <% } %>
          <span class="pcard__badge pcard__badge--new">New</span>
        </div>
        <div class="pcard__body">
          <% if (product.brand_name) { %><span class="pcard__brand"><%= product.brand_name %></span><% } %>
          <div class="pcard__name"><%= product.name %></div>
          <div class="pcard__pricing">
            <% if (product.discount_price) { %>
              <span class="pcard__price pcard__price--sale">R<%= Number(product.discount_price).toFixed(2) %></span>
              <span class="pcard__price-original">R<%= Number(product.price).toFixed(2) %></span>
            <% } else { %>
              <span class="pcard__price">R<%= Number(product.price).toFixed(2) %></span>
            <% } %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- ══════════════════════════════════════════════
       TRENDING / TECH DEALS
  ══════════════════════════════════════════════ -->
  <% if (trending && trending.length > 0) { %>
  <section class="home-section fade-up" id="trending" aria-label="Trending Deals">
    <div class="deals-section">
      <div class="home-section__header">
        <h2 class="home-section__title" style="color:#fff;">⚡ Trending Deals</h2>
        <a href="/products?sort=newest" class="home-section__link">See all →</a>
      </div>
      <div class="product-scroll" role="list">
        <% trending.forEach((product, i) => { %>
        <a href="/products/<%= product.slug || product.id %>"
           class="pcard"
           role="listitem"
           id="trending-product-<%= product.id %>"
           aria-label="<%= product.name %>">
          <div class="pcard__img-wrap">
            <% if (product.image_url) { %>
              <img src="<%= product.image_url %>" alt="<%= product.name %>" class="pcard__img" loading="lazy">
            <% } else { %>
              <div class="pcard__img-placeholder" aria-hidden="true">⚡</div>
            <% } %>
            <span class="pcard__badge pcard__badge--trending">Trending</span>
          </div>
          <div class="pcard__body">
            <% if (product.brand_name) { %><span class="pcard__brand"><%= product.brand_name %></span><% } %>
            <div class="pcard__name"><%= product.name %></div>
            <div class="pcard__pricing">
              <% if (product.discount_price) { %>
                <span class="pcard__price pcard__price--sale">R<%= Number(product.discount_price).toFixed(2) %></span>
                <span class="pcard__price-original">R<%= Number(product.price).toFixed(2) %></span>
              <% } else { %>
                <span class="pcard__price">R<%= Number(product.price).toFixed(2) %></span>
              <% } %>
            </div>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

</div><!-- /home-wrap -->

<!-- ══════════════════════════════════════════════
     FOOTER
══════════════════════════════════════════════ -->
<footer class="site-footer">
  <div class="container">
    <p>© <%= new Date().getFullYear() %> Bauba. Built with Node.js, Express &amp; PostgreSQL.</p>
  </div>
</footer>

<script src="/js/main.js"></script>
<script>
/* ── Intersection Observer: fade-up sections on scroll ── */
(function () {
  const els = document.querySelectorAll('.fade-up');
  if (!els.length) return;
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  els.forEach(el => io.observe(el));

  /* Hero is above fold — make it visible immediately */
  const heroContent = document.querySelector('.hero .fade-up');
  if (heroContent) {
    setTimeout(() => heroContent.classList.add('visible'), 80);
  }
})();
</script>
</body>
</html>
